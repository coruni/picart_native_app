+                )
+            }
+
+            if (style.has("fontSize")) {
+                val fontSize = style.getDouble("fontSize").toFloat()
+                spannable.setSpan(
+                    AbsoluteSizeSpan(dpToPx(fontSize.toInt())),
+                    0,
+                    end,
+                    Spanned.SPAN_EXCLUSIVE_EXCLUSIVE
+                )
+            }
+
+            val fontWeight = if (style.has("fontWeight")) style.getString("fontWeight") else null
+            val fontStyle = if (style.has("fontStyle")) style.getString("fontStyle") else null
+            val isBold = fontWeight == "bold" || fontWeight == "700" || fontWeight == "600" || fontWeight == "500"
+            val isItalic = fontStyle == "italic"
+            val typefaceStyle = when {
